# LexGrid Environment Configuration
# Fill in OPENAI_API_KEY before starting services.
# NEVER commit a file with real secrets to version control.

# ── OpenAI (REQUIRED) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Models (optional — defaults shown) ───────────────────────────────────────
EMBEDDING_MODEL=openai/text-embedding-3-small
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lexgrid:lexgrid@localhost:5432/lexgrid

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Pipeline ──────────────────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=100
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
CONTEXT_MAX_TOKENS=4000

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── Paths ─────────────────────────────────────────────────────────────────────
LEGAL_ACTS_DIR=./legal-acts

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
